      const hay=(d.univ+" "+d.region+" "+d.type+" "+d.y2027+" "+d.y2026).toLowerCase();
      if(!hay.includes(q)) return false;
    }
    return true;
  });
  const s=state.sort;
  if(s==="univ") r=[...r].sort((a,b)=>a.univ.localeCompare(b.univ,"ko"));
  else if(s==="type") r=[...r].sort((a,b)=>TYPES.indexOf(a.type)-TYPES.indexOf(b.type)||a.univ.localeCompare(b.univ,"ko"));
  else if(s==="region") r=[...r].sort((a,b)=>REGIONS.indexOf(a.region)-REGIONS.indexOf(b.region)||a.univ.localeCompare(b.univ,"ko"));
  return r;
}

/* ── render ───────────────────────────── */
function render(){
  const rows = filtered();
  document.getElementById("cnt").textContent = rows.length;
  renderDash(rows);

  const list = document.getElementById("list");
  if(rows.length===0){
    list.innerHTML = `<div class="empty"><div class="big">조건에 맞는 변경사항이 없습니다.</div><div>지역·전형 필터를 넓히거나 검색어를 바꿔 보세요.</div></div>`;
    document.getElementById("foot").textContent="";
    return;
  }
  const frag=document.createDocumentFragment();
  for(const d of rows){
    const ops = diff(d.y2026, d.y2027);
    const oldH = d.isNew ? `<span class="empty-old">— 2026 해당 전형 없음 —</span>` : renderCol(ops,"old");
    const newH = renderCol(ops,"new");
    const card=document.createElement("div");
    card.className="card"+(d.isNew?" new-card":"");
    card.innerHTML = `
      <div class="chead">
        <span class="uname">${esc(d.univ)}</span>
        <span class="rtag">${esc(d.region)}</span>
        <span class="ttag ${TYPE_SHORT[d.type]}">${esc(d.type)}</span>
        ${d.isNew?'<span class="newtag">신설</span>':''}
        <span class="cidx">#${d.id}</span>
      </div>
      <div class="cols">
        <div class="col c-26"><div class="col-h"><span class="dot"></span><span class="yr">2026</span> 현행</div><div class="body">${oldH}</div></div>
        <div class="col c-27"><div class="col-h"><span class="dot"></span><span class="yr">2027</span> 변경</div><div class="body">${newH}</div></div>
      </div>`;
    frag.appendChild(card);
  }
  list.innerHTML="";
  list.appendChild(frag);
  document.getElementById("foot").textContent = `※ 본 도구는 업로드된 비교표를 시각화한 것으로, 확정 사항은 각 대학 모집요강을 확인하십시오.`;
}

function renderDash(rows){
  const byType={}; TYPES.forEach(t=>byType[t]=0);
  const univs=new Set(); let nNew=0;
  rows.forEach(d=>{ byType[d.type]++; univs.add(d.univ); if(d.isNew)nNew++; });
  const dash=document.getElementById("dash");
  const cells=[
    {num:rows.length, lab:"변경 건수", key:null},
    {num:univs.size, lab:"대학 수", key:null},
    {num:byType["학생부교과"], lab:"학생부교과", key:"학생부교과"},
    {num:byType["학생부종합"], lab:"학생부종합", key:"학생부종합"},
    {num:byType["수능"], lab:"수능", key:"수능"},
    {num:nNew, lab:"신설 전형", key:"NEW"},
  ];
  dash.innerHTML = cells.map(c=>{
    const click = c.key?"click":"";
    const on = (c.key && c.key!=="NEW" && state.type===c.key) || (c.key==="NEW" && state.newOnly) ? "on":"";
    return `<div class="stat ${click} ${on}" data-key="${c.key||''}"><div class="num">${c.num}</div><div class="lab">${c.lab}</div></div>`;
  }).join("");
  dash.querySelectorAll(".stat.click").forEach(el=>{
    el.onclick=()=>{
      const k=el.dataset.key;
      if(k==="NEW"){ state.newOnly=!state.newOnly; syncNewToggle(); }
      else { state.type = state.type===k ? "전체" : k; syncTypeChips(); }
      render();
    };
  });
}

/* ── build filter chips ───────────────── */
function buildChips(){
  const rr=document.getElementById("regionRow");
  const counts={}; DATA.forEach(d=>counts[d.region]=(counts[d.region]||0)+1);
  const mk=(label,val,grp,c)=>{
    const b=document.createElement("button");
    b.className="chip"+(val===(grp==="region"?state.region:state.type)?" on":"");
    b.innerHTML = label + (c!=null?`<span class="c">${c}</span>`:"");
    b.dataset.val=val; b.dataset.grp=grp;
    b.onclick=()=>{
      if(grp==="region") state.region = state.region===val?"전체":(val==="전체"?"전체":val);
      else state.type = state.type===val?"전체":(val==="전체"?"전체":val);
      if(val==="전체"){ if(grp==="region")state.region="전체"; else state.type="전체"; }
      grp==="region"?syncRegionChips():syncTypeChips();
      render();
    };
    return b;
  };
  rr.appendChild(mk("전체","전체","region",DATA.length));
  REGIONS.forEach(r=>{ if(counts[r]) rr.appendChild(mk(r,r,"region",counts[r])); });

  const tr=document.getElementById("typeRow");
  const tc={}; DATA.forEach(d=>tc[d.type]=(tc[d.type]||0)+1);
  tr.appendChild(mk("전체","전체","type",DATA.length));
  TYPES.forEach(t=>tr.appendChild(mk(t,t,"type",tc[t]||0)));
}
function syncRegionChips(){ document.querySelectorAll('#regionRow .chip').forEach(c=>c.classList.toggle("on", c.dataset.val===state.region || (c.dataset.val==="전체"&&state.region==="전체"))); }
function syncTypeChips(){ document.querySelectorAll('#typeRow .chip').forEach(c=>c.classList.toggle("on", c.dataset.val===state.type || (c.dataset.val==="전체"&&state.type==="전체"))); }
function syncNewToggle(){ document.getElementById("newChk").checked=state.newOnly; document.getElementById("newToggle").classList.toggle("on",state.newOnly); }

/* ── wire controls ────────────────────── */
const qIn=document.getElementById("q"), clr=document.getElementById("clr");
let qTimer;
qIn.oninput=()=>{ clr.style.display=qIn.value?"block":"none"; clearTimeout(qTimer); qTimer=setTimeout(()=>{state.q=qIn.value.trim();render();},160); };
clr.onclick=()=>{ qIn.value="";state.q="";clr.style.display="none";render();qIn.focus(); };
document.getElementById("newChk").onchange=e=>{ state.newOnly=e.target.checked; syncNewToggle(); render(); };
document.getElementById("sort").onchange=e=>{ state.sort=e.target.value; render(); };
document.getElementById("reset").onclick=()=>{
  Object.assign(state,{q:"",region:"전체",type:"전체",newOnly:false,sort:"orig"});
  qIn.value="";clr.style.display="none";document.getElementById("sort").value="orig";
  syncRegionChips();syncTypeChips();syncNewToggle();render();
};

buildChips();
render();
</script>
