/* ── token diff (LCS) ─────────────────── */
const TOK = /[가-힣]+|[A-Za-z]+|[0-9]+|\s+|[^\s가-힣A-Za-z0-9]/g;
function tokenize(s){ return s.match(TOK) || []; }
function diff(aStr,bStr){
  const a=tokenize(aStr), b=tokenize(bStr);
  // safety guard for very long strings -> fall back to segment compare
  if(a.length*b.length > 60000){
    return segDiff(aStr,bStr);
  }
  const n=a.length,m=b.length;
  const dp=Array.from({length:n+1},()=>new Uint16Array(m+1));
  for(let i=n-1;i>=0;i--)for(let j=m-1;j>=0;j--)
    dp[i][j]= a[i]===b[j] ? dp[i+1][j+1]+1 : Math.max(dp[i+1][j],dp[i][j+1]);
  const ops=[]; let i=0,j=0;
  while(i<n&&j<m){
    if(a[i]===b[j]){ops.push(["eq",a[i]]);i++;j++;}
    else if(dp[i+1][j]>=dp[i][j+1]){ops.push(["del",a[i]]);i++;}
    else{ops.push(["ins",b[j]]);j++;}
  }
  while(i<n){ops.push(["del",a[i++]]);}
  while(j<m){ops.push(["ins",b[j++]]);}
  return ops;
}
function segDiff(aStr,bStr){
  const as=aStr.split("|"), bs=bStr.split("|");
  const bset=new Set(bs.map(s=>s.trim())), aset=new Set(as.map(s=>s.trim()));
  const ops=[];
  // crude: emit dels for a-only, ins for b-only, eq otherwise — reconstruct per column later
  // represent as token-like with pipe separators preserved
  bs.forEach((s,k)=>{ if(k)ops.push(["both","|"]); ops.push([aset.has(s.trim())?"eq":"ins",s]); });
  // for old column we need dels; store separately
  ops._old=[]; as.forEach((s,k)=>{ if(k)ops._old.push(["both","|"]); ops._old.push([bset.has(s.trim())?"eq":"del",s]); });
  ops._seg=true;
  return ops;
}

function esc(s){return s.replace(/[&<>]/g,c=>({"&":"&amp;","<":"&lt;",">":"&gt;"}[c]));}

// render one column from diff ops. side = "old" -> keep eq+del ; "new" -> keep eq+ins
function renderCol(ops, side){
  if(ops._seg){
    const src = side==="old" ? ops._old : ops;
    let html="";
    src.forEach(([t,v])=>{
      if(v==="|"){ html+="<br>"; return; }
      if(t==="eq"||t==="both") html+=esc(v);
      else if(t==="del"&&side==="old") html+=`<mark class="del">${esc(v)}</mark>`;
      else if(t==="ins"&&side==="new") html+=`<mark class="add">${esc(v)}</mark>`;
      else html+=esc(v);
    });
    return html.replace(/^(<br>)+/,"");
  }
  let html="";
  for(const [t,v] of ops){
    const isPipe = v==="|";
    if(isPipe){ html+="<br>"; continue; }
    if(t==="eq"){ html+=esc(v); }
    else if(t==="del"){ if(side==="old") html+=`<mark class="del">${esc(v)}</mark>`; }
    else if(t==="ins"){ if(side==="new") html+=`<mark class="add">${esc(v)}</mark>`; }
  }
  // trim leading line breaks from " | " split spacing
  return html.replace(/^(\s|<br>)+/,"");
}

