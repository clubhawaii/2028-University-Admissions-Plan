<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
<title>2026 → 2027 대입전형 변경사항</title>
<link rel="preconnect" href="https://cdn.jsdelivr.net">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.min.css">
<style>
:root{
  --paper:#FFFFFF;
  --bg:#FFFFFF;
  --surface:#FFFFFF;
  --surface-2:#F5F4F2;
  --ink:#191919;
  --muted:#9A8D92;
  --faint:#9A8D92;
  --line:#F0EEE8;
  --line2:#F5F4F2;
  --line-strong:#E1DED6;
  --navy:#FF5F9F;
  --navy2:#E03C7E;
  --navy-soft:#FFE2EE;
  --card-pt:#2A4F9A;
  /* 비교 컬럼: 무채색 기반 + 변경부만 하이라이트 */
  --c26:#9A8D92;
  --c26-bg:#F5F4F2;
  --c26-mark:#EDE7E2;
  --c27:#191919;
  --c27-bg:#FFFFFF;
  --c27-mark:#FFE2EE;
  --new:#FF5F9F;
  --new-bg:#FFE2EE;
  --sans:"Pretendard Variable",Pretendard,-apple-system,"Apple SD Gothic Neo","Malgun Gothic",sans-serif;
  --mono:var(--sans);
  --sh:0 1px 2px rgba(0,0,0,.04),0 4px 14px rgba(0,0,0,.04);
}
*{box-sizing:border-box;margin:0;padding:0}
html{-webkit-text-size-adjust:100%}
body{
  font-family:var(--sans);
  background:var(--paper);
  color:var(--ink);
  line-height:1.65;
  font-size:15.5px;
  letter-spacing:-.016em;
  font-feature-settings:"tnum";
  -webkit-font-smoothing:antialiased;
  padding-bottom:48px;
}
mark{background:#FFE48A;color:inherit;border-radius:2px;padding:0 .12em;font-weight:inherit}
b,strong{font-weight:700}
.wrap{max-width:1240px;margin:0 auto;padding:0 2rem}

/* ── Header (64대학 톤) ───────────────── */
header.bar{position:sticky;top:0;z-index:60;background:#fff;color:var(--ink);
  border-bottom:1px solid var(--line)}
.bar-in{max-width:1240px;margin:0 auto;padding:0 2rem}
.bar-top{display:flex;align-items:center;gap:18px;height:66px;padding-right:130px}
.home-btn{display:inline-flex;align-items:center;gap:6px;color:var(--muted);font-family:var(--sans);
  font-size:13px;font-weight:700;text-decoration:none;border:1px solid var(--line);background:#fff;
  padding:7px 13px;border-radius:9px;cursor:pointer;transition:all .14s;white-space:nowrap;flex:none}
.home-btn:hover{border-color:var(--navy);color:var(--navy);background:var(--navy-soft)}
.home-btn svg{flex:none}
.brand{display:flex;align-items:baseline;gap:11px;cursor:pointer;flex:none;flex-wrap:wrap}
.brand .yr{font-family:var(--mono);font-weight:700;font-size:12px;letter-spacing:.01em;
  color:var(--navy);padding-left:15px;position:relative;white-space:nowrap}
.brand .yr::before{content:'';position:absolute;left:0;top:50%;transform:translateY(-50%);
  width:8px;height:8px;border-radius:50%;background:var(--navy)}
.brand h1{font-size:18px;font-weight:800;letter-spacing:-.03em;color:var(--ink)}
.brand .sub{font-size:11.5px;color:var(--muted);font-family:var(--sans);letter-spacing:0}
@media(max-width:640px){ .brand .sub{display:none} .bar-top{padding-right:96px;gap:12px} }

/* ── Dashboard ────────────────────────── */
.dash{
  display:grid;grid-template-columns:repeat(6,1fr);gap:1px;
  background:var(--line);border:1px solid var(--line);border-radius:12px;
  overflow:hidden;margin:18px 0 4px;
}
.stat{
  background:var(--surface);padding:13px 14px;cursor:default;
  transition:background .12s;
}
.stat.click{cursor:pointer}
.stat.click:hover{background:var(--surface-2)}
.stat.on{background:var(--ink)}
.stat.on .num,.stat.on .lab{color:#fff}
.stat .num{font-family:var(--mono);font-size:23px;font-weight:700;letter-spacing:-.02em;line-height:1.1;color:var(--ink)}
.stat .lab{font-size:11.5px;color:var(--muted);margin-top:3px;font-weight:600}
.stat.t교과 .num{color:var(--ink)}
.stat.on .num{color:#fff}

/* ── Controls ─────────────────────────── */
.controls{
  background:var(--surface);border:1px solid var(--line);border-radius:12px;
  padding:14px 16px;margin:14px 0 18px;
}
.search{position:relative;margin-bottom:13px}
.search svg{position:absolute;left:9px;top:50%;transform:translateY(-50%);color:#fff;
  background:var(--ink);width:30px;height:30px;padding:7px;border-radius:8px;box-sizing:border-box}
.search input{
  width:100%;font-family:var(--sans);font-size:16px;color:var(--ink);
  padding:13px 42px 13px 48px;border:1.5px solid var(--ink);border-radius:12px;
  background:var(--surface);transition:background .15s,box-shadow .15s;
}
.search input::placeholder{color:var(--muted)}
.search input:focus{outline:none;background:#fff;box-shadow:0 0 0 3px rgba(25,25,25,.12)}
.search .clr{position:absolute;right:10px;top:50%;transform:translateY(-50%);
  border:none;background:none;color:var(--muted);cursor:pointer;font-size:18px;
  width:24px;height:24px;border-radius:6px;display:none;line-height:1}
.search .clr:hover{color:var(--ink);background:var(--line)}

.filt-row{display:flex;flex-wrap:wrap;gap:7px;align-items:center;margin-bottom:9px}
.filt-row:last-child{margin-bottom:0}
.flabel{font-size:11px;font-weight:700;color:var(--faint);letter-spacing:.05em;
  width:42px;flex:none;font-family:var(--mono);text-transform:uppercase}
.chip{
  font-family:var(--sans);font-size:13.5px;font-weight:700;
  padding:9px 13px;border:1px solid var(--line-strong);border-radius:9px;
  background:#fff;color:#5A5A5A;cursor:pointer;transition:all .14s;white-space:nowrap;letter-spacing:-.015em;
}
.chip:hover{background:#F7F5F0;border-color:var(--ink);color:var(--ink)}
.chip.on{background:var(--navy);border-color:var(--navy);color:#fff}
.chip.on::before{content:"✓";margin-right:5px;font-size:11px;font-weight:800}
.chip .c{font-family:var(--mono);font-size:11px;opacity:.72;margin-left:5px;font-weight:600}
.chip.on .c{opacity:.85}

.row2{display:flex;gap:10px;align-items:center;flex-wrap:wrap;margin-top:11px;
  padding-top:11px;border-top:1px dashed var(--line)}
.toggle{display:inline-flex;align-items:center;gap:7px;cursor:pointer;user-select:none;font-size:13px;font-weight:600;color:var(--muted)}
.toggle input{display:none}
.tt{width:36px;height:20px;border-radius:999px;background:var(--line-strong);position:relative;transition:background .14s;flex:none}
.tt::after{content:"";position:absolute;width:16px;height:16px;border-radius:50%;background:#fff;top:2px;left:2px;transition:left .14s;box-shadow:0 1px 2px rgba(0,0,0,.2)}
.toggle input:checked + .tt{background:var(--navy)}
.toggle input:checked + .tt::after{left:18px}
.toggle.on{color:var(--navy2);font-weight:700}
.spacer{flex:1}
.sortsel{font-family:var(--sans);font-size:12.5px;font-weight:700;color:var(--ink);border:1px solid var(--line-strong);
  border-radius:9px;padding:8px 11px;background:#fff;cursor:pointer}
.sortsel:focus{outline:none;border-color:var(--ink)}
.reset{font-size:12.5px;color:var(--muted);background:none;border:1px solid var(--line-strong);
  border-radius:9px;padding:8px 12px;cursor:pointer;font-weight:700}
.reset:hover{border-color:var(--navy);color:var(--navy)}

/* ── Result meta ──────────────────────── */
.meta{display:flex;align-items:center;justify-content:space-between;
  margin:0 2px 12px;font-size:13px;color:var(--muted)}
.meta b{color:var(--ink);font-family:var(--mono);font-weight:700}
.legend{display:flex;gap:13px;align-items:center;font-size:11.5px;color:var(--faint)}
.legend span{display:inline-flex;align-items:center;gap:5px}
.lg{width:13px;height:13px;border-radius:3px;display:inline-block;border:1px solid var(--line)}
.lg.add{background:var(--navy-soft);border-color:var(--navy)}
.lg.del{background:var(--c26-mark)}

/* ── Cards (64대학 톤) ────────────────── */
.list{display:flex;flex-direction:column;gap:11px}
.card{
  background:var(--surface);border:1px solid var(--line);border-radius:13px;
  overflow:hidden;box-shadow:var(--sh);transition:border-color .14s,box-shadow .14s;
}
.card:hover{border-color:var(--card-pt)}
.card.new-card{border-color:var(--navy);box-shadow:0 0 0 1px var(--navy-soft)}
.chead{display:flex;align-items:center;gap:9px;flex-wrap:wrap;
  padding:13px 16px;border-bottom:1px solid var(--line);background:#fff}
.uname{font-size:16px;font-weight:800;letter-spacing:-.02em}
.rtag{font-size:11.5px;color:var(--muted);background:#fff;border:1px solid var(--line);
  padding:2px 8px;border-radius:6px;font-weight:700}
.ttag{font-size:11.5px;font-weight:700;padding:2px 9px;border-radius:6px;letter-spacing:-.01em;
  background:#fff;color:var(--ink);border:1px solid var(--line)}
.ttag.교과,.ttag.종합,.ttag.수능,.ttag.논술{background:#fff;color:var(--ink);border:1px solid var(--line)}
.newtag{font-family:var(--mono);font-size:10.5px;font-weight:700;letter-spacing:.06em;
  background:var(--navy);color:#fff;padding:3px 8px;border-radius:6px}
.cidx{margin-left:auto;font-family:var(--mono);font-size:11px;color:var(--faint)}

.cols{display:grid;grid-template-columns:1fr 1fr}
.col{padding:14px 16px}
.col.c-26{background:var(--line2);border-right:1px solid var(--line)}
.col.c-27{background:#fff}
.col-h{display:flex;align-items:center;gap:7px;margin-bottom:9px;
  font-family:var(--mono);font-size:11px;font-weight:700;letter-spacing:.05em}
.col.c-26 .col-h{color:var(--muted)}
.col.c-27 .col-h{color:var(--ink)}
.col-h .dot{width:7px;height:7px;border-radius:50%}
.col.c-26 .dot{background:var(--muted)}
.col.c-27 .dot{background:var(--navy)}
.col-h .yr{font-size:13px;font-weight:700}
.body{font-size:13.5px;line-height:1.62;color:var(--ink);word-break:break-word}
.body .seg{display:block;padding:1px 0}
.body .seg + .seg{margin-top:1px}
mark.add{background:var(--navy-soft);color:var(--navy2);border-radius:3px;padding:0 2px;font-weight:700}
mark.del{background:var(--c26-mark);color:#6B6460;border-radius:3px;padding:0 2px;text-decoration:line-through;text-decoration-color:rgba(107,100,96,.55)}
.empty-old{color:var(--faint);font-style:normal;font-size:13px}

/* ── Empty / footer ──────────────────── */
.empty{text-align:center;padding:74px 20px;color:var(--muted)}
.empty .big{font-size:15.5px;font-weight:800;color:var(--ink);margin-bottom:6px}
footer{text-align:center;margin-top:28px;font-size:12px;color:var(--faint);font-family:var(--sans);letter-spacing:-.005em;line-height:1.7}

@media (max-width:760px){
  .dash{grid-template-columns:repeat(3,1fr)}
  .cols{grid-template-columns:1fr}
  .col.c-26{border-right:none;border-bottom:1px solid var(--line)}
  .flabel{width:100%}
  .head-inner{padding:18px 16px 16px}
  .col{padding:13px 14px}
}
@media (prefers-reduced-motion:reduce){*{transition:none!important}}


/* ===== HCUI shared layer (theme-consistent home / terms / FAB) ===== */
:root{ --hc-brand:#FF5F9F; --hc-brand2:#E03C7E; --hc-accent:#FF5F9F; --hc-accent2:#E03C7E;
  --hc-ink:#191919; --hc-muted:#9A8D92; --hc-line:#F0EEE8; --hc-paper:#fff; --hc-soft:#FFE2EE;
  --hc-good:#0C6E51; --hc-good-bg:#E3F6EE; --hc-mid:#9A5A0C; --hc-mid-bg:#FDF0DC;
  --hc-weak:#DC2626; --hc-weak-bg:#FEE2E2; --hc-none:#9aa6b4; }
.hc-fab{position:fixed;top:0;right:16px;height:66px;z-index:2147483000;display:flex;gap:9px;align-items:center}
.hc-btn{display:inline-flex;align-items:center;gap:8px;border:none;cursor:pointer;font-family:inherit;
  font-weight:800;border-radius:13px;transition:transform .14s,box-shadow .14s;line-height:1}
.hc-btn:hover{transform:translateY(-2px)}
.hc-term{background:var(--hc-brand);color:#fff;
  font-size:15px;padding:13px 18px;box-shadow:0 8px 22px -6px rgba(255,95,159,.45)}
.hc-term .ic{display:inline-grid;place-items:center;width:24px;height:24px;border-radius:50%;
  background:rgba(255,255,255,.28);font-size:15px;font-weight:900}
.hc-home{background:var(--hc-paper);color:var(--hc-brand);border:1.5px solid var(--hc-line);
  font-size:14px;padding:12px 15px;box-shadow:0 6px 18px -8px rgba(0,0,0,.12)}
.hc-home:hover{border-color:var(--hc-brand2)}
.hc-home .ic{font-size:17px}
/* guide tooltip (말풍선) */
.hc-tooltip{position:absolute;top:calc(100% + 10px);left:50%;transform:translateX(-50%);
  background:#fff;border:1.5px solid var(--hc-brand);border-radius:10px;padding:8px 12px 8px 14px;
  font-family:inherit;font-size:13px;font-weight:700;color:var(--hc-brand);white-space:nowrap;
  opacity:0;transition:opacity .5s;pointer-events:none;box-shadow:0 4px 12px rgba(255,95,159,.18);
  z-index:10;display:inline-flex;align-items:center;gap:8px}
.hc-tooltip::before{content:'';position:absolute;bottom:100%;left:50%;transform:translateX(-50%);
  border:7px solid transparent;border-bottom-color:var(--hc-brand)}
.hc-tooltip.show{opacity:1;pointer-events:auto}
.hc-tip-x{border:none;background:none;color:var(--hc-brand);cursor:pointer;font-size:15px;
  line-height:1;padding:0 0 0 2px;font-weight:400;opacity:.7;transition:opacity .14s;flex:none}
.hc-tip-x:hover{opacity:1}
@media(max-width:640px){
  .hc-fab{right:10px;gap:7px}
  .hc-term{font-size:13px;padding:11px 13px}
  .hc-term .lbl-full{display:none}.hc-term .lbl-short{display:inline}
  .hc-home{padding:11px 12px}.hc-home .lbl{display:none}
  .hc-tooltip{left:auto;right:-4px;transform:none;white-space:nowrap;max-width:none}
  .hc-tooltip::before{left:auto;right:18px;transform:none}
}
@media(min-width:641px){ .hc-term .lbl-short{display:none} }

/* overlay shell (guide + terms) */
.hc-ov{position:fixed;inset:0;z-index:2147482000;background:rgba(12,40,40,.55);
  backdrop-filter:blur(4px);display:none;align-items:flex-start;justify-content:center;
  padding:26px 16px;overflow:auto}
.hc-ov.open{display:flex}
.hc-sheet{background:var(--hc-paper);width:100%;max-width:860px;border-radius:22px;overflow:hidden;
  box-shadow:0 30px 80px -30px rgba(12,40,40,.6);animation:hcpop .26s cubic-bezier(.2,.9,.3,1)}
@keyframes hcpop{from{transform:translateY(14px);opacity:.4}to{transform:none;opacity:1}}
.hc-sheet.sm{max-width:600px}

/* guide (poster-style) */
.hc-ghead{background:linear-gradient(135deg,var(--hc-brand),var(--hc-brand2));color:#fff;
  padding:28px 30px 26px;position:relative;overflow:hidden}
.hc-ghead .wm{position:absolute;right:-10px;bottom:-34px;font-size:130px;font-weight:900;
  letter-spacing:-.04em;color:rgba(255,255,255,.08);line-height:1;pointer-events:none}
.hc-eyebrow{font-size:12px;font-weight:800;letter-spacing:.2em;color:rgba(255,255,255,.7);text-transform:uppercase}
.hc-ghead h2{font-size:30px;font-weight:900;letter-spacing:-.03em;line-height:1.12;margin:9px 0 0;position:relative}
.hc-ghead p{font-size:15px;color:rgba(255,255,255,.85);margin:12px 0 0;max-width:90%;line-height:1.5;position:relative}
.hc-gclose{position:absolute;top:18px;right:20px;z-index:3;width:36px;height:36px;border-radius:50%;
  border:none;background:rgba(255,255,255,.2);color:#fff;font-size:20px;cursor:pointer;line-height:1}
.hc-gclose:hover{background:rgba(255,255,255,.34)}
.hc-gbody{padding:26px 30px 20px}
.hc-kick{font-size:14px;font-weight:800;color:var(--hc-brand);letter-spacing:.02em;display:flex;
  align-items:center;gap:10px;margin:0 0 14px}
.hc-kick::after{content:"";flex:1;height:2px;background:var(--hc-line)}
.hc-methods{display:flex;flex-direction:column;gap:11px;margin-bottom:20px}
.hc-m{display:flex;gap:15px;align-items:flex-start;border:1.5px solid var(--hc-line);border-radius:15px;padding:15px 16px;background:#fff}
.hc-m .no{flex:none;width:46px;height:46px;border-radius:13px;background:var(--hc-soft);color:var(--hc-brand);
  display:grid;place-items:center;font-size:22px;font-weight:900}
.hc-m .ti{font-size:18px;font-weight:800;letter-spacing:-.01em}
.hc-m .de{font-size:14px;color:var(--hc-muted);margin-top:4px;line-height:1.5}
.hc-m .out{font-size:12.5px;color:var(--hc-brand);font-weight:700;margin-top:7px}
.hc-m .out::before{content:"→ "}
.hc-read{border:1.5px solid var(--hc-line);border-radius:15px;padding:16px 18px;margin-bottom:18px}
.hc-read h3{font-size:14px;font-weight:800;color:var(--hc-ink);margin:0 0 11px}
.hc-read .r{font-size:13.5px;color:var(--hc-ink);line-height:1.5;display:flex;gap:8px;margin-bottom:8px}
.hc-read .r:last-child{margin-bottom:0}
.hc-read .r::before{content:"●";color:var(--hc-brand);font-size:8px;margin-top:6px}
.hc-read .r b{color:var(--hc-brand2)}
.hc-scale{display:flex;gap:8px;flex-wrap:wrap;margin-top:12px;align-items:center}
.hc-gb{min-width:54px;text-align:center;font-weight:800;border-radius:9px;padding:7px 6px;font-size:14px}
.hc-gb.g{background:var(--hc-good-bg);color:var(--hc-good)}
.hc-gb.m{background:var(--hc-mid-bg);color:var(--hc-mid)}
.hc-gb.w{background:var(--hc-weak-bg);color:var(--hc-weak)}
.hc-gb.n{background:#eef1f4;color:#9aa6b4}
.hc-start{width:100%;margin-top:4px;border:none;border-radius:16px;padding:18px;cursor:pointer;font-family:inherit;
  background:var(--hc-brand);color:#fff;display:flex;align-items:center;
  justify-content:center;gap:12px;box-shadow:0 14px 30px -12px rgba(255,95,159,.45);transition:transform .15s}
.hc-start:hover{transform:translateY(-2px)}
.hc-start .t{font-size:17px;font-weight:800}
.hc-start .ar{font-size:20px}
.hc-cap{background:#FFF5F8;border-top:1.5px solid var(--hc-line);padding:14px 30px;font-size:12px;
  color:var(--hc-muted);line-height:1.6}
.hc-cap b{color:var(--hc-ink)}

/* terms modal */
.hc-thead{background:linear-gradient(135deg,var(--hc-accent),var(--hc-accent2));color:#fff;
  padding:18px 22px;display:flex;align-items:center;gap:12px;position:sticky;top:0}
.hc-thead .ic{width:34px;height:34px;border-radius:10px;background:rgba(255,255,255,.25);display:grid;place-items:center;font-size:18px;font-weight:900;flex:none}
.hc-thead h2{font-size:18px;font-weight:800;margin:0;flex:1}
.hc-thead .x{width:32px;height:32px;border-radius:8px;border:none;background:rgba(255,255,255,.22);color:#fff;font-size:19px;cursor:pointer;line-height:1}
.hc-thead .x:hover{background:rgba(255,255,255,.38)}
.hc-tbody{padding:8px 22px 22px;max-height:72vh;overflow:auto}
.hc-tsect{font-size:11.5px;font-weight:800;color:var(--hc-muted);letter-spacing:.06em;margin:16px 0 4px}
.hc-trow{display:grid;grid-template-columns:130px 1fr;gap:12px;padding:11px 0;border-bottom:1px dashed var(--hc-line)}
.hc-trow:last-child{border-bottom:none}
.hc-tterm{font-weight:800;color:var(--hc-brand);font-size:13.5px}
.hc-tdesc{font-size:13px;color:var(--hc-ink);line-height:1.5}
@media(max-width:560px){ .hc-trow{grid-template-columns:1fr;gap:3px} }

</style>
</head>
<body>
<header class="bar">
  <div class="bar-in">
    <div class="bar-top">
      <a href="index.html" class="home-btn" title="홈으로">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>홈
      </a>
      <div class="brand">
        <span class="yr">2026 → 2027</span><h1>대입전형 변경사항</h1>
        <span class="sub" id="sub">전국 123개 대학 · 224건 변경 · 지역·전형·키워드 다각도 탐색</span>
      </div>
    </div>
  </div>
</header>

<div class="wrap">
