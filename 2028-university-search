// 저작권 footer를 canvas로 그려 PNG로 반환 (jsPDF 기본 폰트가 한글 미지원이므로 이미지로 삽입)
function buildFooterImg(){
  var lines=["모든 저작권은 (주)이즈유에 있으며, 무단 전재 및 재배포를 엄격히 금지합니다.",
             "ⓒ2021. ISYOU all rights reserved."];
  var W=1400,H=100,dpr=2;
  var c=document.createElement("canvas");
  c.width=W*dpr; c.height=H*dpr;
  var x=c.getContext("2d");
  x.scale(dpr,dpr);
  x.fillStyle="#9A8D92"; x.textAlign="center"; x.textBaseline="middle";
  x.font='600 24px Pretendard,"Malgun Gothic",sans-serif';
  x.fillText(lines[0], W/2, 34);
  x.fillText(lines[1], W/2, 70);
  return {data:c.toDataURL("image/png"), ratio:W/H};
}

function ensureHtml2pdf(cb){
  if(window.html2pdf)return cb();
  var s=document.createElement("script");
  s.src="https://cdn.jsdelivr.net/npm/html2pdf.js@0.10.3/dist/html2pdf.bundle.min.js";
  s.onload=function(){cb();};
  s.onerror=function(){alert("PDF 모듈을 불러오지 못했습니다. 인터넷 연결을 확인해 주세요.");};
  document.head.appendChild(s);
}

function printCmp(){
  var sel=state.sel;
  if(!sel.length)return;
  var N=sel.length;
  var NUM=["①","②","③","④","⑤"];
  var gtc="grid-template-columns:104px repeat("+N+",minmax(0,1fr))";
  var schoolsJoined=sel.map(function(i){return DATA[i].n;}).join(" · ");

  // ----- 대학 헤더 (페이지마다 반복) — 화면 비교표와 동일한 형태 -----
  function headHTML(){
    var h='<div class="p-hdr" style="'+gtc+'"><div></div>';
    sel.forEach(function(i,idx){
      var u=DATA[i];
      var nm0=u.r.filter(function(r){return r.nm0;}).length;
      h+='<div><div class="t"><span class="idx">'+NUM[idx]+'</span><span class="nm">'+esc(u.n)+'</span></div>'
        +'<div class="loc">'+esc(u.l)+'</div>'
        +'<div class="sum"><span class="s1">전형 '+u.r.length+'개</span>'
        +(nm0?'<span class="s2">최저없음 '+nm0+'</span>':'')+'</div></div>';
    });
    return h+'</div>';
  }
  var titleHTML='<div class="p-title"><span class="ttl">2028 대입 시행계획</span>'
    +'<span class="tag">비교 분석 · '+N+'개 대학</span>'
    +'<span class="sch">'+esc(schoolsJoined)+'</span></div>';

  // ----- 카테고리별 속성 행을 "흐름 블록" 배열로 구성 -----
  var blocks=[]; // {t:'band'|'row', html}
  ["kg","jh","ns"].forEach(function(cat){
    var perSchool=sel.map(function(i){return DATA[i].r.filter(function(r){return r.c===cat;});});
    if(!perSchool.some(function(rs){return rs.length;}))return;
    var arow=function(label,fn,cls){
      var row='<div class="p-row '+(cls||'')+'" style="'+gtc+'"><div class="p-lbl">'+label+'</div>';
      perSchool.forEach(function(rs){
        var cell;
        if(!rs.length)cell='<span class="p-none">—</span>';
        else cell=rs.map(function(r,k){
          var pre=rs.length>1?'<span class="num">'+NUM[k]+'</span>':'';
          return '<span class="it">'+pre+fn(r)+'</span>';
        }).join("");
        row+='<div class="p-val">'+cell+'</div>';
      });
      return row+'</div>';
    };
    blocks.push({t:'band',html:'<div class="p-band">'+CATNAME[cat]+'</div>'});
    blocks.push({t:'row',html:arow("전형",function(r){return '<span class="tn">'+esc(r.nm)+'</span>';})});
    blocks.push({t:'row',html:arow("전형방법",function(r){return esc(methodShort(r.mt));})});
    blocks.push({t:'row',html:arow("수능최저",function(r){return r.nm0?'<span class="su-none">없음 / 미적용</span>':esc(r.su);})});
    blocks.push({t:'row',html:arow("변경",function(r){
      var ch=parseChanges(r.ch);
      if(!ch.length)return '<span class="p-nochg">변경 없음</span>';
      return ch.map(function(c){
        return '<span class="chg-it">'+(c.k?'<span class="ck">'+esc(c.k)+'</span>':'')
          +'<span class="cv">'+esc(c.v).replace(/→/g,'<span class="ar">→</span>')+'</span></span>';
      }).join("");
    },"wide")});
  });

  // 스타일 1회 주입
  if(!document.getElementById("pdfStyle")){
    var st=document.createElement("style"); st.id="pdfStyle"; st.textContent=PDF_CSS;
    document.head.appendChild(st);
  }

  // ----- 높이 측정용 컨테이너 (실제 PDF 폭 1040px 고정) -----
  var meas=document.createElement("div"); meas.id="pdfRoot";
  meas.style.cssText="position:absolute;left:-99999px;top:0;width:1040px;max-width:none";
  meas.innerHTML=titleHTML+headHTML()+blocks.map(function(b){return b.html;}).join("");
  document.body.appendChild(meas);
  var titleH=meas.children[0].offsetHeight;
  var hdrH=meas.children[1].offsetHeight;
  var blockH=[];
  for(var bi=0;bi<blocks.length;bi++)blockH[bi]=meas.children[2+bi].offsetHeight;
  document.body.removeChild(meas);

  // ----- 페이지 높이(소스 px) 계산 후 헤더를 매 페이지 반복하며 페이지 분리 -----
  // A4 가로: 콘텐츠폭 277mm ↔ 1040px, 콘텐츠높이 180mm → px 환산
  var pxPerMm=1040/277;
  var pageH=180*pxPerMm;   // ≈ 675.8px
  var SAFETY=28;           // 반올림·여백 보호
  var budget=pageH-SAFETY;

  var out=titleHTML+headHTML();
  var used=titleH+hdrH;
  for(var bi=0;bi<blocks.length;bi++){
    var h=blockH[bi];
    var need=h;
    // 밴드가 페이지 하단에 홀로 남지 않도록 다음 행까지 함께 고려
    if(blocks[bi].t==="band"&&bi+1<blocks.length)need+=blockH[bi+1];
    var fresh=(used<=hdrH+ (bi===0?titleH:0)); // 헤더만 있는 빈 페이지 여부
    if(used+need>budget&&!fresh){
      out+='<div class="html2pdf__page-break"></div>'+headHTML();
      used=hdrH;
    }
    out+=blocks[bi].html;
    used+=h;
  }

  // 캡처용 컨테이너 — html2canvas가 빈 캔버스로 캡처하지 않도록 화면 안(오버레이)에 렌더
  var oldOv=document.getElementById("pdfOverlay");
  if(oldOv)oldOv.remove();
  var overlay=document.createElement("div"); overlay.id="pdfOverlay";
  overlay.innerHTML="<div class='pdf-status'>PDF를 만들고 있어요… 잠시만 기다려 주세요</div>";
  var root=document.createElement("div"); root.id="pdfRoot";
  root.innerHTML=out;
  overlay.appendChild(root);
  document.body.appendChild(overlay);

  var foot=buildFooterImg();
  var opt={
    margin:[10,10,20,10],
    filename:"2028 대입 시행 계획_이즈유.pdf",
    image:{type:"jpeg",quality:0.98},
    html2canvas:{scale:2,useCORS:true,backgroundColor:"#ffffff"},
    jsPDF:{unit:"mm",format:"a4",orientation:"landscape"},
    pagebreak:{mode:["css","legacy"],avoid:[".p-hdr",".p-band",".chg-it",".it"]}
  };

  var cleanup=function(){if(overlay)overlay.remove();};
  ensureHtml2pdf(function(){
    window.html2pdf().set(opt).from(root).toPdf().get("pdf").then(function(pdf){
      var n=pdf.internal.getNumberOfPages();
      var W=pdf.internal.pageSize.getWidth(), H=pdf.internal.pageSize.getHeight();
      var fw=180, fh=fw/foot.ratio;
      for(var i=1;i<=n;i++){
        pdf.setPage(i);
        pdf.addImage(foot.data,"PNG",(W-fw)/2,H-fh-4,fw,fh);
      }
    }).save().then(cleanup,cleanup);
  });
}

