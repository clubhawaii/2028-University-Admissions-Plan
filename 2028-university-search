main.addEventListener("click",e=>{
  const sel=e.target.closest("[data-sel]");
  if(sel){e.stopPropagation();const i=+sel.dataset.sel;
    if(state.sel.includes(i))state.sel=state.sel.filter(x=>x!==i);
    else if(state.sel.length<3)state.sel.push(i);
    else{showToast("최대 3개까지만 선택할 수 있습니다");_skipScroll=true;render();return;}
    _skipScroll=true;render();return;}
  const uni=e.target.closest("[data-uni]"), home=e.target.closest("[data-home]");
  const scope=e.target.closest("[data-scope]"), grp=e.target.closest("[data-grp]");
  const rm=e.target.closest("[data-rm]"), pick=e.target.closest("[data-pick]");
  if(e.target.closest("#pptbtn")){exportPPT();return;}
  if(home){state.uni=null;render();return;}
  if(uni){state.tab="dir";state.uni=+uni.dataset.uni;window.scrollTo(0,0);render();return;}
  if(scope){state.scope=scope.dataset.scope;render();return;}
  if(grp){const g=GROUPS[+grp.dataset.grp];state._pool=g.m.slice();state.sel=g.m.slice(0,3);render();return;}
  if(rm){state.sel=state.sel.filter(x=>x!=+rm.dataset.rm);render();return;}
  if(pick){const i=+pick.dataset.pick;
    if(state.sel.includes(i))state.sel=state.sel.filter(x=>x!=i);
    else if(state.sel.length<3)state.sel.push(i);
    render();return;}
});
