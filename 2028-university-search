function syncChrome(){
  document.querySelectorAll(".tab").forEach(b=>b.dataset.on=b.dataset.tab===state.tab?"1":"0");
  document.querySelectorAll(".fbtn").forEach(b=>b.dataset.on=(b.dataset.f==="all"?state.filter==null:b.dataset.f===state.filter)?"1":"0");
  clr.style.display=state.q?"block":"none";
  const showSearch=(state.tab==="dir"&&state.uni==null)||state.tab==="matrix";
  $("#barsub").style.display=showSearch?"flex":"none";
  const inDetail=state.tab==="dir"&&state.uni!=null;
  const tabbar=document.getElementById("tabbar");if(tabbar)tabbar.style.display=inDetail?"none":"";
  const homeBtn=document.querySelector(".home-btn");if(homeBtn)homeBtn.style.display=inDetail?"none":"";
  // update selection bar
  const selBar=document.getElementById("selBar");
  const selCnt=document.getElementById("selCnt");
  const cmpBtn=document.getElementById("cmpOpenBtn");
  if(selBar&&state.tab==="dir"&&state.uni==null){
    if(state.sel.length>0){selBar.classList.add("show");}
    else{selBar.classList.remove("show");}
    if(cmpBtn)cmpBtn.disabled=state.sel.length<3;
    if(selCnt){
      if(state.sel.length===0)selCnt.innerHTML="대학을 선택하세요 (최대 3개)";
      else{
        const names=state.sel.map(i=>'<b class="sel-nm">'+esc(DATA[i].n)+'</b>').join('<span class="sel-dot">·</span>');
        selCnt.innerHTML="<span class='sel-lead'>선택</span> "+names+
          " <span class='sel-hint'>("+state.sel.length+"/3"+(state.sel.length<3?" · 3개 선택 시 비교":"")+")</span>";
      }
    }
  } else if(selBar){
    selBar.classList.remove("show");
  }
}
