        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        PDF 저장
      </button>
      <button class="cmp-closebtn" onclick="closeCmpModal()">&times;</button>
    </div>
    <div class="cmp-mbody" id="cmpMbody"></div>
  </div>
</div>
<script>
  let DATA = [];

const WORKER_URL = "https://university-search.diosumd0943.workers.dev";

async function loadWorkerData() {
  const response = await fetch(WORKER_URL + "?keyword=__all__");

  if (!response.ok) {
    throw new Error("Worker 데이터 요청 실패");
  }

  DATA = await response.json();

  DATA.sort((a, b) => (a.mj || 999) - (b.mj || 999));
}
const GROUPS = [{"t": "서울대·연세대·고려대", "m": [0, 1, 2]}, {"t": "서강대·성균관대·한양대", "m": [4, 3, 5]}, {"t": "중앙대·이화여대", "m": [6, 10]}, {"t": "경희대·시립대·외대", "m": [7, 9, 8]}, {"t": "건국대·동국대·홍익대·숙명여대", "m": [11, 12, 18, 13]}, {"t": "국민대·숭실대·세종대", "m": [14, 15, 17]}, {"t": "단국대·광운대", "m": [19, 20]}, {"t": "상명대·명지대·가톨릭대·가천대·경기대", "m": [27, 21, 22, 35, 40]}, {"t": "아주대·인하대·한양대에리카", "m": [34, 32, 36]}];
const CATNAME = {kg:"학생부 교과", jh:"학생부 종합", ns:"논술"};
const CATSHORT = {kg:"교과", jh:"종합", ns:"논술"};
const FNAME = {kg:"교과전형", jh:"종합전형", ns:"논술전형", nomin:"수능최저 없는 전형"};
const REGIONS = ["서울","경기·인천","과학기술원","지방거점국립"];
let state = {tab:"dir", filter:null, uni:null, q:"", scope:"major", sel:[]};

const $ = s => document.querySelector(s);
const main = $("#main"), qInput = $("#q"), clr = $("#clr");

function esc(s){return (s||"").replace(/[&<>"]/g,c=>({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;"}[c]));}
function hl(s){
  s=esc(s); const q=state.q.trim(); if(!q)return s;
  const re=new RegExp("("+q.replace(/[.*+?^${}()|[\]\\]/g,"\\$&")+")","gi");
  return s.replace(re,"<mark>$1</mark>");
}
function rowText(u,r){return [u.n,u.l,r.t,r.nm,r.mt,r.su,r.ch].join(" ").toLowerCase();}
function uniText(u){return (u.n+" "+u.l+" "+u.r.map(r=>r.t+r.nm+r.mt+r.su+r.ch).join(" ")).toLowerCase();}
function catCounts(u){const c={kg:0,jh:0,ns:0};u.r.forEach(r=>{if(c[r.c]!=null)c[r.c]++;});return c;}
function shortName(n){
  if(/ERICA/.test(n))return "한양대 ERICA";
  const p=n.match(/\(([^)]+)\)/); if(/과학기술원/.test(n)&&p)return p[1];
  return n.replace(/대학교(\s.*)?$/,"대").replace(/여자대/,"여대");
}
function uniBase(n){return (n||"").replace(/\s+\S*캠퍼스.*$/,"").trim();}
function monogram(n){const core=uniBase(n).replace(/대학교.*$/,"").replace(/대$/,"");return core.slice(0,2);}
function logoBox(n){return `<img src="logos/${esc(uniBase(n))}.png" alt="" loading="lazy" onerror="this.remove()"><b class="mg">${esc(monogram(n))}</b>`;}
function methodShort(mt){
  return (mt||"").replace(/^(일괄합산\s*전형|일괄합산|단계별\s*전형)\s*/,"").replace(/\s+/g," ").trim();
}
function suShort(su){
  su=(su||"").trim(); if(!su)return"";
  const b=su.match(/\[[^\]]+\][^\[]*/); 
  let t=b?b[0]:su; if(t.length>40)t=t.slice(0,40)+"…"; return t;
}

// ===== DIRECTORY =====
function renderDir(){
  if(state.uni!=null)return renderDetail();
  const q=state.q.trim().toLowerCase(); let total=0,html="";
  REGIONS.forEach(rg=>{
    let unis=DATA.map((u,i)=>({u,i})).filter(x=>x.u.rg===rg);
    if(q)unis=unis.filter(x=>uniText(x.u).includes(q));
    if(state.filter)unis=unis.filter(x=>x.u.r.some(r=>matchRow(r,state.filter)));
    if(!unis.length)return; total+=unis.length;
    html+=`<section class="region"><h2>${rg}<span class="c">${unis.length}개교</span></h2><div class="grid">`;
    unis.forEach(({u,i})=>{
      const c=catCounts(u); let chips="";
      ["kg","jh","ns"].forEach(k=>{if(c[k])chips+=`<span class="chip ${k}">${CATSHORT[k]}<span class="qn">${c[k]}</span></span>`;});
      const nm=u.r.filter(r=>r.nm0).length; if(nm)chips+=`<span class="chip nm">${nm}개전형 최저없음</span>`;
      const isSel=state.sel.includes(i);
      html+=`<button class="uni" data-uni="${i}"><div class="top">
        <span class="logobox">${logoBox(u.n)}</span>
        <div class="uinfo"><span class="nm">${hl(u.n)}</span><div class="loc">${hl(u.l)}</div></div></div>
        ${u.mj?'<span class="mjb">주요대</span>':''}<div class="chips">${chips}</div>
        <div class="sel-btn${isSel?" on":""}" data-sel="${i}" role="button" tabindex="0" title="${isSel?"선택 해제":"비교에 추가"}">비교</div></button>`;
    });
    html+=`</div></section>`;
  });
  const fl=state.filter?` · ${FNAME[state.filter]} 보유`:"";
  const crumb=`<div class="crumb"><span class="meta">${q?`검색 "${esc(state.q)}" · `:""}${total}개 대학${fl}</span></div>`;
  main.innerHTML=total?crumb+html:emptyMsg();
}

// ===== MATRIX (한눈에) =====
function matchRow(r,f){return f==="nomin"?r.nm0:r.c===f;}
function renderMatrix(){
  const q=state.q.trim().toLowerCase();
  let pool=DATA.map((u,i)=>({u,i}));
  if(state.scope==="major")pool=pool.filter(x=>x.u.mj);
  const banks={has:{kg:[],jh:[],ns:[]},no:{kg:[],jh:[],ns:[]}};
  let nrows=0;
  pool.forEach(({u,i})=>{
    u.r.forEach(r=>{
      if(state.filter && !matchRow(r,state.filter))return;
      if(q && !rowText(u,r).includes(q))return;
      const cat=r.c; if(!banks.has[cat])return;
      (r.nm0?banks.no:banks.has)[cat].push({u,i,r}); nrows++;
    });
  });
  const scopeTog=`<div class="crumb"><div class="scopetog">
    <button data-scope="major" data-on="${state.scope==='major'?1:0}">주요대 28</button>
    <button data-scope="all" data-on="${state.scope==='all'?1:0}">전체 64</button></div>
    <span class="meta">${q?`"${esc(state.q)}" · `:""}${nrows}개 전형 · 수능최저 기준 분류</span></div>`;
  function colBlock(items,cat){
    let inner="";
    if(!items.length)inner=`<div class="empty-col">해당 없음</div>`;
    else items.sort((a,b)=>a.i-b.i).forEach(({u,i,r})=>{
      const s=r.nm0?`<div class="s nm">수능최저 없음</div>`:`<div class="s">${hl(suShort(r.su))}</div>`;
      inner+=`<div class="mcell" data-uni="${i}"><div class="u">${hl(shortName(u.n))}</div>
        <div class="e">${hl(r.nm)}</div>${s}</div>`;
    });
    return `<div class="mxcol ${cat}"><div class="ch">${CATNAME[cat]}<span class="qn">${items.length}</span></div><div class="body">${inner}</div></div>`;
  }
  function band(key,label,cls){
    const b=banks[key]; const ct=b.kg.length+b.jh.length+b.ns.length;
    if(!ct)return"";
    return `<div class="mx-band ${cls}"><div class="t"><span class="dot"></span>${label}</div><div class="ln"></div><span class="ct">${ct}개 전형</span></div>
      <div class="mxcols">${colBlock(b.kg,'kg')}${colBlock(b.jh,'jh')}${colBlock(b.ns,'ns')}</div>`;
  }
  const body=band('has','수능최저 있음','has')+band('no','수능최저 없음 · 미적용','no');
  main.innerHTML=scopeTog+(nrows?body:emptyMsg());
}

// ===== COMPARE =====
function renderCompare(){
  let html=`<div class="cmp-intro">대학을 최대 <b>3곳</b>까지 골라 전형을 나란히 비교합니다. 아래 묶음을 누르면 후보가 채워지고, 칩을 눌러 선택을 조정하세요. 비교표는 <b>PPT로 저장</b>할 수 있습니다 <span style="color:var(--faint)">(최초 1회 인터넷 연결 필요)</span>.</div>`;
  html+=`<div class="grp-wrap"><div class="grp-lab">자주 쓰는 비교 묶음</div><div class="grps">`;
  GROUPS.forEach((g,gi)=>{html+=`<button class="grp" data-grp="${gi}">${esc(g.t)}</button>`;});
  html+=`</div></div>`;
  // slots
  html+=`<div class="pickbar"><div class="pl" style="display:flex;justify-content:space-between;align-items:center;gap:10px"><span>선택한 대학 (${state.sel.length}/3)</span>${state.sel.length>=2?`<button class="pptbtn" id="pptbtn"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v12"/><path d="m7 12 5 5 5-5"/><path d="M5 21h14"/></svg>PPT로 저장</button>`:``}</div><div class="slots">`;
  for(let k=0;k<3;k++){
    const i=state.sel[k];
    if(i!=null)html+=`<div class="slot filled"><span class="nm">${esc(shortName(DATA[i].n))}</span><button class="x" data-rm="${i}">&times;</button></div>`;
    else html+=`<div class="slot"><span class="ph">대학 ${k+1}</span></div>`;
  }
  html+=`</div><div class="addrow"><input id="addu" list="ulist" placeholder="대학명으로 추가 검색"><datalist id="ulist">`;
  DATA.forEach((u,i)=>{html+=`<option value="${esc(u.n)}">`;});
  html+=`</datalist></div>`;
  // pool chips from currently invoked group (show major as default pool)
  html+=`<div class="poolchips" id="pool">`;
  let poolIdx = state._pool || DATA.map((u,i)=>i).filter(i=>DATA[i].mj);
  poolIdx.forEach(i=>{const on=state.sel.includes(i);
    html+=`<button class="pc" data-pick="${i}" data-on="${on?1:0}">${esc(shortName(DATA[i].n))}</button>`;});
  html+=`</div></div>`;
  // comparison
  if(state.sel.length>=2)html+=renderCmpTable();
  else html+=`<div class="empty"><div class="big">대학 2곳 이상을 선택하세요</div><div class="sm">묶음 버튼이나 검색으로 추가하면 비교표가 나타납니다.</div></div>`;
  main.innerHTML=html;
}
function renderCmpTable(){
  const sel=state.sel, N=sel.length;
  const NUM=["①","②","③","④","⑤"];
  const gtc=`grid-template-columns:96px repeat(${N},minmax(0,1fr))`;
  const CATS=["kg","jh","ns"];
  // 속성 정의 — 그리드/카드 뷰 양쪽에서 공통 사용
  const ATTRS=[
    ["전형",r=>`<span class="tn">${esc(r.nm)}</span>`],
    ["전형방법",r=>esc(methodShort(r.mt))],
    ["수능최저",r=>r.nm0?`<span class="su-none">없음 / 미적용</span>`:esc(r.su)],
    ["변경",r=>{
      const ch=parseChanges(r.ch);
      if(!ch.length)return `<span class="cmp2-nochg">변경 없음</span>`;
      return ch.map(c=>`<span class="chg-it">${c.k?`<span class="ck">${esc(c.k)}</span>`:""}<span class="cv">${esc(c.v).replace(/→/g,'<span class="ar">→</span>')}</span></span>`).join("");
    }]
  ];
  // 한 대학의 한 속성 값 셀 내용 (전형 여러 개면 ①②③ 접두)
  const cellHTML=(rs,fn)=>!rs.length
    ? `<span class="cmp2-none">—</span>`
    : rs.map((r,k)=>`<span class="it">${rs.length>1?`<span class="num">${NUM[k]}</span>`:``}${fn(r)}</span>`).join("");

  /* ===== 데스크톱: 가로 그리드 ===== */
  let uh=`<div class="cmp2-uh"></div>`;
  sel.forEach((i,idx)=>{
    const u=DATA[i];
    const nm0=u.r.filter(r=>r.nm0).length;
    uh+=`<div class="cmp2-uh"><div class="nm"><span class="ix">${NUM[idx]}</span>${esc(u.n)}</div>`
      +`<div class="meta">${esc(u.l)}</div>`
      +`<div class="sum"><span class="s1">전형 ${u.r.length}개</span>`
      +(nm0?`<span class="s2">최저없음 ${nm0}</span>`:``)+`</div></div>`;
  });
  let body="";
  CATS.forEach(cat=>{
    const perSchool=sel.map(i=>DATA[i].r.filter(r=>r.c===cat));
    if(!perSchool.some(rs=>rs.length))return;
    body+=`<div class="cmp2-band">${CATNAME[cat]}</div>`;
    ATTRS.forEach(([label,fn])=>{
      let row=`<div class="cmp2-lbl">${label}</div>`;
      perSchool.forEach(rs=>{ row+=`<div class="cmp2-val">${cellHTML(rs,fn)}</div>`; });
      body+=row;
    });
  });
  const grid=`<div class="cmp2" style="${gtc}">${uh}${body}</div>`;

  /* ===== 모바일: 대학별 세로 카드 ===== */
  let cards="";
  sel.forEach((i,idx)=>{
    const u=DATA[i];
    const nm0=u.r.filter(r=>r.nm0).length;
    let inner="";
    CATS.forEach(cat=>{
      const rs=u.r.filter(r=>r.c===cat);
      if(!rs.length)return;
      inner+=`<div class="cband">${CATNAME[cat]}</div>`;
      ATTRS.forEach(([label,fn])=>{
        inner+=`<div class="cmp2-crow"><div class="cl">${label}</div><div class="cv2">${cellHTML(rs,fn)}</div></div>`;
      });
    });
    cards+=`<div class="cmp2-card"><div class="cmp2-card-h">`
      +`<div class="nm"><span class="ix">${NUM[idx]}</span>${esc(u.n)}</div>`
      +`<div class="meta">${esc(u.l)}</div>`
      +`<div class="sum"><span class="s1">전형 ${u.r.length}개</span>`
      +(nm0?`<span class="s2">최저없음 ${nm0}</span>`:``)+`</div></div>${inner}</div>`;
  });

  return grid+`<div class="cmp2-cards">${cards}</div>`;
}

// ===== DETAIL =====
function renderChanges(ch){
  ch=(ch||"").trim();
  if(!ch||ch==="없음")return `<span class="nochange">변경 없음</span>`;
  const m=[...ch.matchAll(/\[([^\]]+)\]\s*([^\[]*)/g)];
  if(!m.length)return `<div class="body">${hl(ch)}</div>`;
  return m.map(x=>`<div class="delta"><span class="dk">${hl(x[1])}</span><span class="dv">${hl(x[2]).replace(/→/g,'<span class="arrow">→</span>')}</span></div>`).join("");
}
// 변경 내용 파싱 → [{k,v}] (비교 모달·프린트 공용)
function parseChanges(ch){
  ch=(ch||"").trim();
  if(!ch||ch==="없음")return [];
  const m=[...ch.matchAll(/\[([^\]]+)\]\s*([^\[]*)/g)];
  if(!m.length)return [{k:"",v:ch}];
  return m.map(x=>({k:x[1].trim(), v:x[2].trim()}));
}
function renderDetail(){
  const u=DATA[state.uni],c=catCounts(u); let stats="";
  ["kg","jh","ns"].forEach(k=>{if(c[k])stats+=`<span class="chip ${k}">${CATNAME[k]}<span class="qn">${c[k]}</span></span>`;});
  const nm=u.r.filter(r=>r.nm0).length; if(nm)stats+=`<span class="nmtag">수능최저 없음 ${nm}</span>`;
  let html=`<div class="crumb"><button class="back" data-home="1">← 전체 대학</button><span class="meta">${u.rg}</span></div>
    <div class="dhead"><span class="logobox dlogo">${logoBox(u.n)}</span>
    <div class="dbody"><div class="dn">${hl(u.n)}${u.mj?'<span class="mjb">주요대</span>':''}</div>
    <div class="dl">${hl(u.l)} · 주 전형 ${u.cnt}개</div><div class="dstats">${stats}</div></div></div>`;
  u.r.forEach(r=>{
    const su=r.nm0?`<span class="nochange">없음 / 미적용</span>`:`<div class="body">${hl(r.su)}</div>`;
    html+=`<div class="card ${r.c}"><div class="ch"><span class="tag ${r.c}">${CATNAME[r.c]||r.t}</span><span class="cnm">${hl(r.nm)}</span></div>
      <div class="sec"><div class="lbl">전형방법</div><div class="body">${hl(r.mt)}</div></div>
      <div class="sec su"><div class="lbl">수능최저학력기준</div>${su}</div>
      <div class="sec changes"><div class="lbl">2028 변경 내용</div><div class="body">${renderChanges(r.ch)}</div></div></div>`;
  });
  main.innerHTML=html;
}
function emptyMsg(){return `<div class="empty"><div class="big">결과가 없습니다</div><div class="sm">검색어나 필터를 바꿔 보세요.</div></div>`;}

// ===== PPT EXPORT =====
const KF="맑은 고딕";
const CATCOL={kg:"C53030",jh:"1D4ED8",ns:"B45309"};
function loadPptx(){
  return new Promise((res,rej)=>{
    if(window.PptxGenJS)return res(window.PptxGenJS);
    const s=document.createElement("script");
    s.src="https://cdnjs.cloudflare.com/ajax/libs/pptxgenjs/3.12.0/pptxgen.bundle.js";
    s.onload=()=>window.PptxGenJS?res(window.PptxGenJS):rej(new Error("no global"));
    s.onerror=()=>rej(new Error("load fail"));
    document.head.appendChild(s);
  });
}
function uniCatCell(i,cat){
  const rs=DATA[i].r.filter(r=>r.c===cat);
  if(!rs.length)return {text:"—",options:{color:"98A0AC",align:"center",valign:"middle",fontFace:KF,fontSize:13}};
  const runs=[];
  rs.forEach((r,idx)=>{
    if(idx)runs.push({text:"\n",options:{fontSize:7}});
    runs.push({text:r.nm+"\n",options:{bold:true,fontSize:11.5,color:"13161B"}});
    runs.push({text:methodShort(r.mt)+"\n",options:{fontSize:9,color:"444C59"}});
    if(r.nm0)runs.push({text:"수능최저 없음\n",options:{fontSize:9,color:"0E7C6B",bold:true}});
    else runs.push({text:"최저 "+(r.su||"")+"\n",options:{fontSize:9,color:"222222"}});
    if(r.ch&&r.ch!=="없음")runs.push({text:"▲ 변경 있음\n",options:{fontSize:8.5,color:"B45309",bold:true}});
  });
  return {text:runs,options:{valign:"top",fontFace:KF,margin:6}};
}
async function exportPPT(){
  const btn=document.getElementById("pptbtn"); const sel=state.sel.slice();
  if(sel.length<2)return;
  if(btn){btn.disabled=true;btn.lastChild.textContent="PPT 생성 중…";}
  try{
    const P=await loadPptx();
    const pptx=new P(); pptx.layout="LAYOUT_WIDE"; // 13.33 x 7.5
    // 표지
    const t=pptx.addSlide(); t.background={color:"FF5F9F"};
    t.addText("2028 수시 전형 비교",{x:0.6,y:2.5,w:12.1,h:0.9,fontFace:KF,fontSize:40,bold:true,color:"FFFFFF"});
    t.addText(sel.map(i=>DATA[i].n).join("    vs    "),{x:0.6,y:3.65,w:12.1,h:0.6,fontFace:KF,fontSize:20,color:"FFD4E8"});
    t.addText("교과 · 종합 · 논술 전형 비교  |  시행계획 기준",{x:0.6,y:6.7,w:12.1,h:0.4,fontFace:KF,fontSize:12,color:"FFB3D4"});
    const n=sel.length, colW=Array(n).fill(12.73/n);
    ["kg","jh","ns"].forEach(cat=>{
      if(!sel.some(i=>DATA[i].r.some(r=>r.c===cat)))return;
      const s=pptx.addSlide(); s.background={color:"FFFFFF"};
      s.addText("2028 수시 전형 비교",{x:0.3,y:0.24,w:12.7,h:0.3,fontFace:KF,fontSize:12,color:"98A0AC"});
