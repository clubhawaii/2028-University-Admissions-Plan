<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>2028 대입 시행계획 · 64개 대학</title>
<link rel="preconnect" href="https://cdn.jsdelivr.net">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.min.css">
<style>
:root{
  --paper:#FFFFFF; --surface:#ffffff; --ink:#191919; --muted:#9A8D92; --faint:#9A8D92;
  --line:#F0EEE8; --line2:#F5F4F2; --navy:#FF5F9F; --navy2:#E03C7E; --navy-soft:#FFE2EE;
  --card-pt:#2A4F9A; --card-pt2:#1E3C78; --card-pt-soft:#EAEFF8;
  --kg:#DC2626; --kg-bg:#FDE9E7; --kg-line:#F6BDB8;
  --jh:#2563EB; --jh-bg:#E6EDFF; --jh-line:#BBD0FB; 
  --ns:#9A5A0C; --ns-bg:#FDF0DC; --ns-line:#E8D5A8;
  --nomin:#0C6E51; --nomin-bg:#E3F6EE;
  --mono:ui-monospace,SFMono-Regular,Menlo,"Roboto Mono",monospace;
  --sans:"Pretendard Variable",Pretendard,-apple-system,"Apple SD Gothic Neo","Malgun Gothic",sans-serif;
  --sh:0 1px 2px rgba(0,0,0,.04),0 4px 14px rgba(0,0,0,.04);
}
*{box-sizing:border-box;margin:0;padding:0}
html{-webkit-text-size-adjust:100%}
body{font-family:var(--sans);background:var(--paper);color:var(--ink);
  line-height:1.65;font-size:15.5px;letter-spacing:-.016em;
  font-feature-settings:"tnum";-webkit-font-smoothing:antialiased}
mark{background:#FFE48A;color:inherit;border-radius:2px;padding:0 .12em;font-weight:inherit}
b,strong{font-weight:700}

/* ===== top bar ===== */
header.bar{position:sticky;top:0;z-index:60;background:#fff;color:var(--ink);
  border-bottom:1px solid var(--line)}
.bar-in{max-width:1240px;margin:0 auto;padding:0 2rem}
.bar-top{display:flex;align-items:center;gap:18px;height:66px;padding-right:130px}
.brand{display:flex;align-items:baseline;gap:11px;cursor:pointer;flex:none}
.brand .yr{font-family:var(--mono);font-weight:700;font-size:12px;letter-spacing:.01em;
  color:var(--navy);background:transparent;padding:0 0 0 15px;border-radius:0;position:relative}
.brand .yr::before{content:'';position:absolute;left:0;top:50%;transform:translateY(-50%);width:8px;height:8px;border-radius:50%;background:var(--navy)}
.brand h1{font-size:18px;font-weight:800;letter-spacing:-.03em;color:var(--ink)}
.brand .sub{font-size:11.5px;color:var(--muted);font-family:var(--sans);letter-spacing:0}
/* 탭 바 — 고정 헤더 아래 별도 배치 */
.tabbar{background:#fff;border-bottom:1px solid var(--line)}
.tabbar .bar-in{display:flex}
nav.tabs{display:flex;gap:6px;padding:9px 0}
.tab{border:1px solid var(--line);background:#fff;color:var(--muted);font-family:var(--sans);font-size:14.5px;
  font-weight:700;padding:8px 18px;border-radius:10px;cursor:pointer;letter-spacing:-.02em;
  transition:all .14s;white-space:nowrap}
.tab:hover{color:var(--ink);border-color:var(--ink)}
.tab[data-on="1"]{color:#fff;background:var(--navy);border-color:var(--navy)}
.bar-sub-wrap{background:#fff}
.bar-sub{display:flex;flex-direction:column;gap:8px;padding:12px 0 13px}
.search{position:relative;width:100%}
.search-label{font-size:32px;font-weight:800;color:var(--ink);letter-spacing:-.01em;line-height:1.5;margin:44px 0 22px;font-family:var(--sans);text-align:center}
.search input{width:100%;border:1.5px solid var(--ink);background:var(--surface);
  border-radius:12px;padding:13px 42px 13px 48px;font-family:var(--sans);font-size:16px;
  color:var(--ink);outline:none;transition:background .15s,box-shadow .15s}
.search input::placeholder{color:var(--muted)}
.search input:focus{background:#fff;color:var(--ink);box-shadow:0 0 0 3px rgba(25,25,25,.12)}
.search input:focus::placeholder{color:var(--faint)}
.search svg{position:absolute;left:9px;top:50%;transform:translateY(-50%);color:#fff;
  background:var(--ink);width:30px;height:30px;padding:6px;border-radius:8px;box-sizing:border-box}
.search input:focus + .clr{color:var(--muted)}
.search .clr{position:absolute;right:9px;top:50%;transform:translateY(-50%);
  border:none;background:none;color:var(--muted);cursor:pointer;font-size:17px;display:none;
  padding:2px 6px;border-radius:6px;line-height:1}
.filters{display:flex;gap:7px;overflow-x:auto;scrollbar-width:none}
.filters::-webkit-scrollbar{display:none}
.fbtn{flex:none;border:1px solid #E1DED6;background:#fff;
  color:#5A5A5A;font-family:var(--sans);font-size:13.5px;font-weight:700;padding:9px 13px;
  border-radius:9px;cursor:pointer;white-space:nowrap;transition:all .14s;letter-spacing:-.015em}
.fbtn:hover{background:#F7F5F0;border-color:#191919}
.fbtn .n{font-family:var(--mono);font-size:11px;opacity:.72;margin-left:5px;font-weight:600}
.fbtn[data-on="1"]{color:#fff;border-color:var(--navy);background:var(--navy)}
.fbtn[data-on="1"]::before{content:"✓";margin-right:5px;font-size:11px;font-weight:800}
.fbtn.kg[data-on="1"]{background:var(--navy)} .fbtn.jh[data-on="1"]{background:var(--navy)}
.fbtn.ns[data-on="1"]{background:var(--navy)} .fbtn.nm[data-on="1"]{background:var(--navy)}

/* ===== main ===== */
main{max-width:1240px;margin:0 auto;padding:24px 2rem 90px}
.crumb{display:flex;align-items:center;gap:9px;margin-bottom:18px;flex-wrap:wrap}
.crumb button.back{border:1px solid var(--line);background:var(--surface);color:var(--card-pt);
  font-family:var(--sans);font-size:13px;font-weight:700;cursor:pointer;padding:6px 12px;
  border-radius:8px;letter-spacing:-.01em;transition:all .14s}
.crumb button.back:hover{border-color:var(--card-pt);background:var(--card-pt-soft)}
.meta{font-family:var(--sans);font-size:12px;color:var(--muted)}
.hd{font-size:14px;font-weight:800;letter-spacing:-.02em;color:var(--ink);margin:0 0 4px}
.scopetog{display:inline-flex;border:1px solid var(--line);border-radius:9px;overflow:hidden;background:var(--surface)}
.scopetog button{border:none;background:none;font-family:var(--sans);font-size:13px;font-weight:700;
  padding:7px 14px;cursor:pointer;color:var(--muted);letter-spacing:-.01em}
.scopetog button[data-on="1"]{background:var(--navy);color:#fff}

/* ===== directory ===== */
.region{margin-bottom:30px;animation:fade .28s ease}
.region h2{font-size:13.5px;font-weight:800;color:var(--card-pt);letter-spacing:-.01em;
  margin-bottom:13px;display:flex;align-items:center;gap:10px}
.region h2:after{content:"";flex:1;height:1.5px;background:var(--line)}
.region h2 .c{font-family:var(--mono);font-weight:600;font-size:11px;color:var(--faint)}
.grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(232px,1fr));gap:11px}
.uni{background:var(--surface);border:1px solid var(--line);border-radius:13px;
  padding:15px 16px;cursor:pointer;transition:transform .14s,box-shadow .14s,border-color .14s;
  display:flex;flex-direction:column;gap:9px;text-align:left}
.uni:hover{transform:translateY(-2px);border-color:var(--card-pt)}
.uni:focus-visible{outline:2px solid var(--card-pt);outline-offset:2px}
.uni .top{display:flex;align-items:center;gap:10px}
.uni .uinfo{min-width:0;display:flex;flex-direction:column;gap:2px}
.logobox{width:44px;height:44px;border-radius:11px;flex:none;display:grid;place-items:center;
  background:#fff;border:1px solid var(--line);position:relative;overflow:hidden;
  font-weight:800;font-size:15px;color:var(--ink);letter-spacing:-.04em}
.logobox img{position:absolute;inset:0;width:100%;height:100%;object-fit:contain;padding:5px;background:#fff;border-radius:inherit}
.uni .nm{font-size:19px;font-weight:700;letter-spacing:-.025em;line-height:1.28}
.uni .mjb{font-size:9.5px;font-weight:800;color:var(--ink);background:#fff;border:1px solid var(--line);
  padding:1px 6px;border-radius:4px;letter-spacing:.02em;align-self:flex-start}
.uni .loc{font-size:12px;color:var(--muted);font-family:var(--sans);letter-spacing:-.01em}
.chips{display:flex;gap:5px;flex-wrap:wrap}
.chip{font-size:11px;font-weight:700;padding:2px 7px;border-radius:5px;letter-spacing:-.01em;
  display:inline-flex;align-items:center;gap:2px;border:1px solid transparent}
.chip .qn{font-family:var(--sans);font-size:11px;font-weight:700;opacity:1}
.chip.kg{background:#fff;color:var(--ink);border-color:var(--line)}
.chip.jh{background:#fff;color:var(--ink);border-color:var(--line)}
.chip.ns{background:#fff;color:var(--ink);border-color:var(--line)}
.chip.nm{background:#F2F5FB;color:#3A5EAA;border-color:#DCE4F2;font-size:11px}

/* ===== matrix (한눈에) ===== */
.mx-band{display:flex;align-items:center;gap:10px;margin:26px 0 14px}
.mx-band .t{font-size:16px;font-weight:800;letter-spacing:-.025em;display:flex;align-items:center;gap:8px}
.mx-band .dot{width:10px;height:10px;border-radius:50%}
.mx-band.has .dot{background:var(--navy)} .mx-band.no .dot{background:var(--nomin)}
.mx-band .ln{flex:1;height:1.5px;background:var(--line)}
.mx-band .ct{font-family:var(--mono);font-size:11.5px;color:var(--faint)}
.mxcols{display:grid;grid-template-columns:repeat(3,1fr);gap:13px}
.mxcol{background:var(--surface);border:1px solid var(--line);border-radius:14px;overflow:hidden}
.mxcol .ch{padding:11px 15px;font-size:13.5px;font-weight:800;letter-spacing:-.02em;
  display:flex;align-items:center;justify-content:space-between;color:#fff}
.mxcol.kg .ch{background:var(--ink)} .mxcol.jh .ch{background:var(--ink)} .mxcol.ns .ch{background:var(--ink)}
.mxcol .ch .qn{font-family:var(--mono);font-size:11px;font-weight:700;opacity:.85}
.mxcol .body{padding:9px;display:flex;flex-direction:column;gap:7px}
.mcell{border:1px solid var(--line);border-left-width:3px;border-radius:9px;padding:9px 11px;
  cursor:pointer;transition:background .13s,border-color .13s,transform .13s;background:#fff}
.mcell:hover{transform:translateX(2px);box-shadow:var(--sh)}
.mxcol.kg .mcell{border-left-color:var(--line)} .mxcol.kg .mcell:hover{background:var(--line2);border-color:var(--navy)}
.mxcol.jh .mcell{border-left-color:var(--line)} .mxcol.jh .mcell:hover{background:var(--line2);border-color:var(--navy)}
.mxcol.ns .mcell{border-left-color:var(--line)} .mxcol.ns .mcell:hover{background:var(--line2);border-color:var(--navy)}
.mcell .u{font-size:13.5px;font-weight:800;letter-spacing:-.02em}
.mcell .e{font-size:12px;color:var(--muted);margin-top:1px}
.mcell .s{font-size:11.5px;color:#3C4452;margin-top:4px;line-height:1.45;font-weight:600}
.mcell .s.nm{color:var(--nomin);font-family:var(--sans);letter-spacing:0}
.mxcol .empty-col{padding:18px 14px;text-align:center;color:var(--faint);font-size:12.5px}

/* ===== compare ===== */
.cmp-intro{font-size:13.5px;color:var(--muted);margin-bottom:14px;line-height:1.6}
.grp-wrap{margin-bottom:8px}
.grp-lab{font-size:12px;font-weight:700;color:var(--navy2);margin-bottom:8px;letter-spacing:-.01em}
.grps{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:18px}
.grp{border:1px solid var(--line);background:var(--surface);color:var(--ink);font-family:var(--sans);
  font-size:13px;font-weight:700;padding:8px 13px;border-radius:9px;cursor:pointer;letter-spacing:-.015em;
  transition:all .14s}
.grp:hover{border-color:var(--navy2);background:var(--navy-soft)}
.pickbar{background:var(--surface);border:1px solid var(--line);border-radius:13px;padding:15px 16px;margin-bottom:18px}
.pickbar .pl{font-size:12.5px;font-weight:800;color:var(--navy2);margin-bottom:10px;letter-spacing:-.01em}
.slots{display:flex;gap:9px;flex-wrap:wrap;margin-bottom:12px}
.slot{flex:1;min-width:130px;border:1.5px dashed var(--line);border-radius:10px;padding:11px 12px;
  display:flex;align-items:center;justify-content:space-between;gap:8px;min-height:46px}
.slot.filled{border-style:solid;border-color:var(--navy2);background:var(--navy-soft)}
.slot .nm{font-size:14px;font-weight:800;letter-spacing:-.02em;color:var(--navy)}
.slot .ph{font-size:12.5px;color:var(--faint);font-family:var(--sans)}
.slot .x{border:none;background:none;color:var(--muted);cursor:pointer;font-size:16px;line-height:1;padding:2px}
.addrow{display:flex;gap:8px;align-items:center}
.addrow input{flex:1;border:1px solid var(--line);border-radius:9px;padding:9px 12px;
  font-family:var(--sans);font-size:14px;outline:none}
.addrow input:focus{border-color:var(--navy);box-shadow:0 0 0 3px var(--navy-soft)}
.poolchips{display:flex;gap:6px;flex-wrap:wrap;margin-top:11px}
.pc{border:1px solid var(--line);background:#fff;font-family:var(--sans);font-size:12.5px;font-weight:600;
  padding:6px 11px;border-radius:8px;cursor:pointer;transition:all .13s;letter-spacing:-.01em}
.pc:hover{border-color:var(--navy2)}
.pc[data-on="1"]{background:var(--navy);color:#fff;border-color:var(--navy)}
.pc[data-on="1"]:hover{background:var(--navy2)}
.pptbtn{border:none;background:var(--ink);color:#fff;font-family:var(--sans);font-size:13px;
  font-weight:800;padding:8px 15px;border-radius:9px;cursor:pointer;letter-spacing:-.01em;
  display:inline-flex;align-items:center;gap:7px;transition:background .14s}
.pptbtn:hover{background:#333}
.pptbtn:disabled{opacity:.55;cursor:default}
.pptbtn svg{flex:none}

/* ===== 비교 매트릭스 (속성별 행 정렬) ===== */
.cmp2{display:grid;gap:0;animation:fade .28s ease;border:1px solid var(--line);border-radius:14px;overflow:hidden;background:var(--surface);min-width:580px}
/* 대학 헤더 — 스크롤 시 상단 고정 */
.cmp2-uh{position:sticky;top:0;z-index:3;background:#fff;padding:13px 14px;border-bottom:2px solid var(--card-pt);border-left:1px solid var(--line2)}
.cmp2-uh:first-child{border-left:none}
.cmp2-uh .nm{display:flex;align-items:baseline;gap:5px;font-size:15.5px;font-weight:800;letter-spacing:-.02em;color:var(--card-pt)}
.cmp2-uh .nm .ix{font-size:12px;font-weight:800;color:var(--navy)}
.cmp2-uh .meta{font-size:11px;color:var(--muted);font-weight:600;margin-top:2px}
.cmp2-uh .sum{display:flex;flex-wrap:wrap;gap:5px;margin-top:8px}
.cmp2-uh .sum span{font-size:10.5px;font-weight:800;border-radius:6px;padding:2px 7px;letter-spacing:-.01em}
.cmp2-uh .sum .s1{background:var(--card-pt-soft);color:var(--card-pt)}
.cmp2-uh .sum .s2{background:var(--nomin-bg);color:var(--nomin)}
/* 카테고리 밴드 (전체폭) */
.cmp2-band{grid-column:1/-1;background:var(--ink);color:#fff;font-size:12px;font-weight:800;letter-spacing:.01em;padding:8px 14px}
/* 속성 라벨 열 */
.cmp2-lbl{background:#FAFBFD;border-top:1px solid var(--line2);padding:10px 12px;font-size:11.5px;font-weight:800;color:#5A6577;letter-spacing:-.01em}
/* 값 셀 */
.cmp2-val{border-top:1px solid var(--line2);border-left:1px solid var(--line2);padding:10px 13px;font-size:12.5px;line-height:1.5;color:#2C333D;word-break:keep-all;overflow-wrap:anywhere}
.cmp2-val .it{display:block;margin-top:6px}
.cmp2-val .it:first-child{margin-top:0}
.cmp2-val .num{color:var(--navy);font-weight:800;font-size:11px;margin-right:4px}
.cmp2-val .tn{font-size:13px;font-weight:800;letter-spacing:-.015em;color:var(--ink)}
.cmp2-val .su-none{color:var(--nomin);font-weight:700}
.cmp2-val .chg-it{display:block;margin-top:4px;line-height:1.45;color:#3A3A3A}
.cmp2-val .chg-it:first-child{margin-top:0}
.cmp2-val .chg-it .ck{display:inline-block;font-weight:800;color:var(--ns);background:var(--ns-bg);border:1px solid var(--ns-line);border-radius:5px;padding:0 6px;margin-right:5px;font-size:10.5px;letter-spacing:-.01em}
.cmp2-val .chg-it .ar{color:var(--ns);font-weight:800;padding:0 3px}
.cmp2-val .cmp2-nochg{color:var(--faint);font-size:12px}
.cmp2-none{color:var(--faint);font-size:12px}
/* 모바일 비교 — 대학별 세로 카드 (기본 숨김, ≤640px에서 노출) */
.cmp2-cards{display:none}
.cmp2-card{border:1px solid var(--line);border-radius:14px;overflow:hidden;background:var(--surface);margin-bottom:14px}
.cmp2-card:last-child{margin-bottom:0}
.cmp2-card-h{padding:14px 15px;border-bottom:2px solid var(--card-pt)}
.cmp2-card-h .nm{display:flex;align-items:baseline;gap:6px;font-size:17px;font-weight:800;letter-spacing:-.02em;color:var(--card-pt)}
.cmp2-card-h .nm .ix{font-size:13px;font-weight:800;color:var(--navy)}
.cmp2-card-h .meta{font-size:12px;color:var(--muted);font-weight:600;margin-top:3px}
.cmp2-card-h .sum{display:flex;flex-wrap:wrap;gap:5px;margin-top:9px}
.cmp2-card-h .sum span{font-size:11px;font-weight:800;border-radius:6px;padding:2px 8px;letter-spacing:-.01em}
.cmp2-card-h .sum .s1{background:var(--card-pt-soft);color:var(--card-pt)}
.cmp2-card-h .sum .s2{background:var(--nomin-bg);color:var(--nomin)}
.cmp2-card .cband{background:var(--ink);color:#fff;font-size:12px;font-weight:800;letter-spacing:.01em;padding:8px 15px}
.cmp2-crow{display:grid;grid-template-columns:74px 1fr;border-top:1px solid var(--line2)}
.cmp2-crow .cl{background:#FAFBFD;padding:10px 9px;font-size:11.5px;font-weight:800;color:#5A6577;letter-spacing:-.02em;word-break:keep-all}
.cmp2-crow .cv2{padding:10px 13px;font-size:13px;line-height:1.55;color:#2C333D;word-break:keep-all;overflow-wrap:anywhere;border-left:1px solid var(--line2)}
.cmp2-crow .cv2 .it{display:block;margin-top:6px}
.cmp2-crow .cv2 .it:first-child{margin-top:0}
.cmp2-crow .cv2 .num{color:var(--navy);font-weight:800;font-size:11px;margin-right:4px}
.cmp2-crow .cv2 .tn{font-size:13.5px;font-weight:800;letter-spacing:-.015em;color:var(--ink)}
.cmp2-crow .cv2 .su-none{color:var(--nomin);font-weight:700}
.cmp2-crow .cv2 .chg-it{display:block;margin-top:4px;line-height:1.45;color:#3A3A3A}
.cmp2-crow .cv2 .chg-it:first-child{margin-top:0}
.cmp2-crow .cv2 .chg-it .ck{display:inline-block;font-weight:800;color:var(--ns);background:var(--ns-bg);border:1px solid var(--ns-line);border-radius:5px;padding:0 6px;margin-right:5px;font-size:10.5px;letter-spacing:-.01em}
.cmp2-crow .cv2 .chg-it .ar{color:var(--ns);font-weight:800;padding:0 3px}
.cmp2-crow .cv2 .cmp2-nochg{color:var(--faint);font-size:12px}
.cmp2-crow .cv2 .cmp2-none{color:var(--faint);font-size:12px}

/* ===== detail ===== */
.dhead{background:var(--surface);border:1px solid var(--line);border-radius:15px;
  padding:20px 22px;margin-bottom:17px;animation:fade .28s ease;
  display:flex;align-items:flex-start;gap:16px}
.dhead .dbody{flex:1;min-width:0}
.dhead .dlogo{width:54px;height:54px;border-radius:13px;font-size:18px}
.dhead .dn{font-size:26px;font-weight:800;letter-spacing:-.04em;display:flex;align-items:center;gap:10px;flex-wrap:wrap}
.dhead .mjb{font-size:11px;font-weight:800;color:#fff;background:var(--ink);padding:3px 9px;border-radius:6px;letter-spacing:.01em}
.dhead .dl{font-size:13px;color:var(--muted);font-family:var(--sans);margin-top:6px;letter-spacing:0}
.dhead .dstats{display:flex;gap:7px;margin-top:14px;flex-wrap:wrap}
.card{background:var(--surface);border:1px solid var(--line);border-radius:14px;margin-bottom:13px;
  overflow:hidden;animation:fade .28s ease}
.card .ch{padding:14px 19px;border-bottom:1px solid var(--line2);display:flex;align-items:center;gap:11px;flex-wrap:wrap}
.card .ch .cnm{font-size:17.5px;font-weight:800;letter-spacing:-.025em}
.tag{font-size:11px;font-weight:800;padding:3px 9px;border-radius:6px;letter-spacing:.01em;flex:none;border:1px solid var(--line)}
.tag.kg{background:#fff;color:var(--ink);border-color:var(--line)}
.tag.jh{background:#fff;color:var(--ink);border-color:var(--line)}
.tag.ns{background:#fff;color:var(--ink);border-color:var(--line)}
